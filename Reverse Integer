class Solution(object):
    def reverse(self, x):
            is_negative = x < 0
            x = abs(x)
        
            res = 0
            while x > 0:
                res = res * 10 + (x % 10)
                x //= 10
        
            if res > 2**31 - 1:
                return 0
        
            res = -res if is_negative else res
        
            if res < -2**31:
                return 0
        
            return res

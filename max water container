
class Solution {
public:
    int maxArea(vector<int>& height) {
        int res = 0;
        int left = 0, right = height.size() - 1;

        while(left < right) {
            int water = right - left;
            int h = min(height[left], height[right]);
            int currWater = water * h;
            res = max(res, currWater);

            height[left] < height[right] ? left++ : right--;
        }

        return res;
    }
};
